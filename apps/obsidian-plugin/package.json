{
  "name": "@llm-translator/obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "prebuild": "npm run -w @llm-translator/core build",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "pretest": "npm run -w @llm-translator/core build",
    "test": "vitest run"
  },
  "dependencies": {
    "@llm-translator/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
